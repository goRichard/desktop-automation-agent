{
  "name": "flowpilot-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "SEWC FlowPilot minimal Electron shell",
  "main": "dist/main/main.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:renderer": "vite --host 127.0.0.1 --port 5173 --strictPort",
    "dev:electron": "npm run build:main && npm run build:preload && node scripts/wait-dev-renderer.mjs && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .",
    "build": "npm run build:renderer && npm run build:main && npm run build:preload",
    "build:renderer": "vite build",
    "build:main": "tsc -p tsconfig.main.json",
    "build:preload": "node scripts/build-preload.mjs",
    "pack:win": "npm run build && electron-builder --win --x64",
    "stage:runtime": "node scripts/stage-runtime.mjs"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "vite": "^7.0.0"
  },
  "devDependencies": {
    "concurrently": "^9.0.0",
    "cross-env": "^10.0.0",
    "electron": "^37.0.0",
    "electron-builder": "^26.0.0",
    "typescript": "^5.8.0",
    "wait-on": "^8.0.0"
  },
  "build": {
    "appId": "com.sewc.flowpilot",
    "productName": "SEWC FlowPilot",
    "directories": {
      "output": "out"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "resources/runtime",
        "to": "runtime",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
