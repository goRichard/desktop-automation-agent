# 开发模式密钥配置（不纳入版本管理）
# 复制此文件为 .env 并填写相应的密钥
# Windows 正式版使用 Credential Manager，config.yaml 只保存 apiKeySecret 引用。

# 本地 vLLM 部署（通常无需 key，留空即可）
LLM_API_KEY=xxxxxxxxxxx
VISION_API_KEY=xxxxxxxxxxxxx

# 云端 OpenAI
OPENAI_API_KEY=sk-xxx

# 云端 Anthropic（如需使用）
ANTHROPIC_API_KEY=sk-ant-xxx


AZURE_OPENAI_API_KEY=xxxxxxxxxxxxxx
